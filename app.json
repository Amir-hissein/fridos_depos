{
  "expo": {
    "name": "fridos",
    "slug": "fridos",
    "scheme": "fridos",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fridos.app",
      "usesAppleSignIn": true
    },
    "android": {
      "package": "com.fridos.app",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-apple-authentication",
      "expo-router",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0C1713",
          "image": "./assets/splash.png",
          "imageWidth": 240,
          "resizeMode": "contain"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Fridos uses the camera to scan the food in your fridge."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Fridos accesses your photos to analyze an image of your fridge."
        }
      ],
      "expo-localization",
      [
        "expo-notifications",
        {
          "color": "#14B8A6"
        }
      ],
      "expo-secure-store",
      "@sentry/react-native",
      "expo-web-browser"
    ]
  }
}
