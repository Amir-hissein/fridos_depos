{
  "expo": {
    "name": "fridos AI",
    "slug": "fridos",
    "scheme": "fridos",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/fridos.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B1413"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fridos.app",
      "usesAppleSignIn": true,
      "splash": {
        "image": "./assets/fridos.png",
        "resizeMode": "contain",
        "backgroundColor": "#0B1413"
      },
      "privacyManifests": {
        "NSPrivacyTracking": false,
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": ["CA92.1"]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryFileTimestamp",
            "NSPrivacyAccessedAPITypeReasons": ["C617.1", "0A2A.1", "3B52.1"]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryDiskSpace",
            "NSPrivacyAccessedAPITypeReasons": ["E174.1", "85F4.1"]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategorySystemBootTime",
            "NSPrivacyAccessedAPITypeReasons": ["35F9.1"]
          }
        ]
      }
    },
    "android": {
      "package": "com.fridos.app",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "splash": {
        "image": "./assets/fridos.png",
        "resizeMode": "contain",
        "backgroundColor": "#0B1413"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-apple-authentication",
      "expo-router",
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "Fridos uses the camera to scan the food in your fridge."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Fridos accesses your photos to analyze an image of your fridge."
        }
      ],
      "expo-localization",
      [
        "expo-notifications",
        {
          "color": "#14B8A6"
        }
      ],
      "expo-secure-store",
      "@sentry/react-native",
      "expo-web-browser"
    ]
  }
}
