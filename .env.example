# Copier ce fichier en .env et remplir les valeurs réelles
# Copy this file to .env and fill in the real values

# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# RevenueCat — clés publiques SDK (Project Settings → API keys)
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_xxxxxxxxxxxxxxxxxxxxxxxx
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_xxxxxxxxxxxxxxxxxxxxxxxx

# Sentry — DSN public (adresse d'ingestion, pas un secret)
EXPO_PUBLIC_SENTRY_DSN=https://xxxxxxxx@o0000000.ingest.sentry.io/0000000
